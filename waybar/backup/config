{
"layer": "top",
"position": "top",
"height": 10,
"margin-bottom":0,
"margin-top":0,

"modules-left": ["clock"],
"modules-center": ["sway/workspaces"],
"modules-right":  ["pulseaudio","network","battery"],

"sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
},
"sway/window": {
	    "format": "{title}",
		"max-length": 333,
	    "seperate-outputs": true,
	    "icon": false
  },
"tray": {
	"icon-size": 16,
	"spacing": 6
},
"clock": {
	"locale": "C", 
	"format": "<span foreground='#E69875'></span><span>{:%H:%M}</span>",
	"format-alt": "’ü│ {:%D}" // Icon: calendar-alt
},
"cpu": {
	"format": "<span foreground='#E69875'> ’ł│</span> {usage}%",
	"tooltip": false,
	"on-click": "kitty -e 'htop'"
},
"memory": {
	"interval": 1,
	"format": "<span foreground='#E69875'>¾░Źø</span> {used:0.2f}GB",
	"max-length": 10,
	"tooltip": false,
	"warning": 70,
	"critical": 90
},
"disk": {
	"interval": 30,
	"format": "<span foreground='#E69875'>’éĀ</span> {percentage_used}%",
},
"network": {
	"interval": 2,
	"format-wifi": "’ć½ {signalStrength}%",
	"format-ethernet": "’āü",
	"format-linked": " {ipaddr}",
	"format-disconnected": "’ü▒ Disconnected",
	"format-disabled": "",
	"tooltip": false,
	"max-length": 20,
	"min-length": 6,
	"format-alt": "{essid}",
},
"idle_inhibitor": {
	"format": "{icon}",
	"format-icons": {
        	"activated": "’ü«",
        	"deactivated": "’ü░"
    }
},
"backlight": {
	// "device": "acpi_video1",
	"format": "{icon}&#8239;{percent}%",
	"format-icons": ["’ā½", "’ā½"],
	"on-scroll-down": "brightnessctl -c backlight set 1%-",
	"on-scroll-up": "brightnessctl -c backlight set +1%"
},
"pulseaudio": {
	"format-source": "<span foreground='#E69875'>’ä░ </span>{volume}%",
	"format-source-muted": "<span foreground='#F38BA8'>’ä▒ </span>",
	"format": "<span foreground='#E69875'>{icon}</span> {volume}%  {format_source}",
	"format-bluetooth": "<span foreground='##E69875'>{icon} </span> {volume}%  {format_source}",
	"format-bluetooth-muted": "<span foreground='#D699B6'>¾░¢ü</span>  {format_source}",
	"format-muted": "<span foreground='#7A8478'>¾░¢ü</span>  {format_source}",
	"format-icons": {
	  "headphone": "’Ćź",
	  "phone": "’éĢ",
	  "portable": "’éĢ",
	  "default": ["’Ć”", "’Ć¦", "’Ć©"]
	},
	"on-click-left": "pavucontrol",
	"input": true
  },
},
 "custom/notification": {
    "tooltip": false,
    "format": "<span foreground='#E69875'> {icon} </span>",
    "format-icons": {
      "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
},
